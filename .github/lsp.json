{
  "lspServers": {
    "csharp": {
      "command": "dotnet",
      "args": [
        "tool",
        "run",
        "roslyn-language-server",
        "--stdio",
        "--autoLoadProjects"
      ],
      "fileExtensions": {
        ".cs": "csharp"
      },
      "rootUri": "dotnet"
    },
    "go": {
      "command": "gopls",
      "args": ["serve"],
      "fileExtensions": {
        ".go": "go"
      },
      "rootUri": "go"
    },
    "rust-analyzer": {
      "command": "rust-analyzer",
      "fileExtensions": {
        ".rs": "rust"
      },
      "initializationOptions": {
        "cargo": {
          "buildScripts": {
            "enable": true
          },
          "allFeatures": true
        },
        "checkOnSave": true,
        "check": {
          "command": "clippy"
        }
      }
    }
  }
}
